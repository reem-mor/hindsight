        }
      }
    },
    {
      "parameters": {
        "operation": "send",
        "sendTo": "=reliability@example.com",
        "subject": "=[{{ $json.e.computed_severity }}] {{ $json.g.incident_title }}",
        "emailType": "html",
        "message": "=<h2>Postmortem processed</h2><p><b>{{ $json.g.incident_title }}</b> \u2014 {{ $json.e.computed_severity }}</p><p>Team: {{ $json.e.department }} \u00b7 Sensitivity: {{ $json.e.sensitivity }}</p><p>{{ $json.g.summary }}</p><p>Routing: {{ ($json.e.routing_tags||[]).join(', ') }}</p><hr><i>HINDSIGHT \u00b7 n8n + Gemini 3</i>",
        "options": {}
      },
      "id": "26967636-9b93-4fc4-8aee-ca390e594225",
      "name": "\ud83d\udce7 Send digest",
      "type": "n8n-nodes-base.gmail",
      "typeVersion": 2,
      "position": [
        3580,
        410
