    {
      "parameters": {
        "operation": "send",
        "sendTo": "=oncall@example.com",
        "subject": "=\ud83d\udea8 SEV1 PAGE \u2014 {{ $json.g.incident_title }} ({{ $json.e.department }})",
        "emailType": "html",
        "message": "=<h2 style='color:#FF4D5E'>SEV1 incident filed</h2><p><b>{{ $json.g.incident_title }}</b></p><p>Team: {{ $json.e.department }} \u00b7 Services: {{ ($json.e.affected_services_resolved||[]).join(', ') }}</p><p>Jurisdictions: {{ ($json.e.affected_jurisdictions||[]).join(', ') }}</p><p>{{ $json.g.summary }}</p><p>Routing: {{ ($json.e.routing_tags||[]).join(', ') }}</p><hr><i>HINDSIGHT \u00b7 auto-paged because computed severity = SEV1</i>",
        "options": {
          "priority": "high"
        }
      },
