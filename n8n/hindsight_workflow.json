          "options": {
            "caseSensitive": true,
            "typeValidation": "loose"
          },
          "conditions": [
            {
              "id": "6e8be39e-0669-4676-95dc-ab8f6b68b871",
              "leftValue": "={{ $json.is_sev1 }}",
              "rightValue": true,
              "operator": {
                "type": "boolean",
