# HINDSIGHT — example configuration. Copy to .env and fill in.
# NEVER commit .env. Gemini / Google OAuth for live n8n also live in n8n credentials.

# ── Local Docker n8n (scripts/import_local_credentials.py + import_selfhosted_workflow.py) ─
N8N_LOCAL_URL=http://127.0.0.1:5678
N8N_LOCAL_EMAIL=hindsight@local.dev
N8N_LOCAL_PASSWORD=change-me-local-only
N8N_LOCAL_GEMINI_CRED_ID=hindsight-gemini-local-001
N8N_LOCAL_SHEETS_CRED_ID=hindsight-sheets-local-001
N8N_LOCAL_GMAIL_CRED_ID=hindsight-gmail-local-001
HINDSIGHT_ALERT_EMAIL=you@example.com

# ── Docker compose (services read env_file: .env) ────────────────────────────
# GEMINI_API_KEY and SUPABASE_* are passed to enrichment-api container.
# HINDSIGHT_SHEET_ID is available inside n8n container for scripts.
GENERIC_TIMEZONE=Asia/Jerusalem
ENRICHMENT_API_URL=http://127.0.0.1:8000

# ── n8n Cloud (scripts/audit_n8n_cloud.py, sync_n8n_cloud_nodes.py, .cursor/mcp.json) ──
N8N_API_URL=https://your-instance.app.n8n.cloud
N8N_API_KEY=your_n8n_api_key_here
HINDSIGHT_SHEET_ID=your_google_sheet_id_here

# ── Sibling course repo (course-tools MCP) ───────────────────────────────────
AMDOCS_COURSE_ROOT=/path/to/amdocs-ai-course

# ── Optional MCP servers (.cursor/mcp.json) ──────────────────────────────────
AWS_PROFILE=default
AWS_REGION=us-east-1
CONTEXT7_API_KEY=your_context7_key_here
PERPLEXITY_API_KEY=your_perplexity_api_key_here
LOVABLE_CLIENT_ID=your_lovable_client_id_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Enrichment API (all optional; sane defaults baked in) ────────────────────
HINDSIGHT_LOG_LEVEL=INFO
HINDSIGHT_JSON_LOGS=true
# Confidence below this flags an incident for human review (0–1)
HINDSIGHT_REVIEW_THRESHOLD=0.7

# Error-budget burn above this fraction trips the budget-breach tag (0–1)
HINDSIGHT_BUDGET_BREACH_FRACTION=0.5

# CORS origins allowed to call the API (comma-separated)
HINDSIGHT_CORS_ORIGINS=*

# ── Dashboard (optional) ─────────────────────────────────────────────────────
# Publish Google Sheet to web as CSV and paste URL into dashboard/index.html SHEETS_CSV_URL.

# ── Semantic search — Supabase pgvector (BON-5; Pinecone noted as alternative) ─
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── Optional bonus flags ─────────────────────────────────────────────────────
# Enable multi-model compare branch when calling POST /compare
HINDSIGHT_COMPARE_MODELS=false
