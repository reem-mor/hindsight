# HINDSIGHT — example configuration. Copy to .env and fill in.
# NEVER commit .env. Gemini / Google OAuth for live n8n also live in n8n credentials.

# ── n8n Cloud (scripts/audit_n8n_cloud.py, sync_n8n_cloud_nodes.py, .cursor/mcp.json) ──
N8N_API_URL=https://reemmor.app.n8n.cloud
N8N_API_KEY=your_n8n_api_key_here
HINDSIGHT_SHEET_ID=1Z7tiPISHB5siYby_lQnWA9wtXbDXVSGTu4HGZ5Dk2tk

# ── Sibling course repo (course-tools MCP) ───────────────────────────────────
AMDOCS_COURSE_ROOT=c:\dev\amdocs-ai-course

# ── Optional MCP servers (.cursor/mcp.json) ──────────────────────────────────
AWS_PROFILE=your_aws_profile_name
AWS_REGION=us-east-1
CONTEXT7_API_KEY=your_context7_key_here
PERPLEXITY_API_KEY=your_perplexity_key_here
LOVABLE_CLIENT_ID=your_lovable_client_id_here
GEMINI_API_KEY=your_gemini_api_key_here

# ── Enrichment API (all optional; sane defaults baked in) ────────────────────
HINDSIGHT_LOG_LEVEL=INFO
HINDSIGHT_JSON_LOGS=true

# Confidence below this flags an incident for human review (0–1)
HINDSIGHT_REVIEW_CONFIDENCE_THRESHOLD=0.7

# Error-budget burn above this fraction trips the budget-breach tag (0–1)
HINDSIGHT_BUDGET_BREACH_FRACTION=0.5

# CORS origins allowed to call the API (comma-separated)
HINDSIGHT_CORS_ORIGINS=*

# ── Dashboard (optional) ─────────────────────────────────────────────────────
# To make the dashboard read live data, publish your Google Sheet to the web as
# CSV and paste the link into SHEETS_CSV_URL at the top of dashboard/index.html.
# Left blank, the dashboard uses the bundled sample registry.
